# ── Environment Variables ─────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Flask secret key — used for session signing. Must be long and random in production.
SECRET_KEY=qf-admin-super-secret-key-change-in-production-2024

# Flask environment: development | production
FLASK_ENV=development

# Database URL (leave blank to use the default SQLite database in instance/)
# For PostgreSQL: postgresql://user:password@localhost:5432/qf_admin
DATABASE_URL=
